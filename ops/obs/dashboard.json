{
  "__inputs": [
    {
      "name": "DS_VICTORIAMETRICS",
      "label": "VictoriaMetrics",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "title": "headscale",
  "uid": "headscale-dashboard",
  "version": 1,
  "schemaVersion": 38,
  "tags": ["headscale", "tailscale", "abstractbike"],
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Service Status",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "targets": [
        {
          "expr": "up{job=\"headscale\"}",
          "legendFormat": "up"
        }
      ],
      "options": {
        "colorMode": "background",
        "thresholds": {
          "steps": [
            { "value": 0, "color": "red" },
            { "value": 1, "color": "green" }
          ]
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Registered Nodes",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "targets": [
        {
          "expr": "headscale_nodes_total",
          "legendFormat": "nodes"
        }
      ],
      "options": { "colorMode": "value" }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Active Users",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "targets": [
        {
          "expr": "headscale_users_total",
          "legendFormat": "users"
        }
      ],
      "options": { "colorMode": "value" }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Active Pre-Auth Keys",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "targets": [
        {
          "expr": "headscale_preauthkeys_total{status=\"used\"}",
          "legendFormat": "used keys"
        }
      ],
      "options": { "colorMode": "value" }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "HTTP Request Rate",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"headscale\"}[5m])",
          "legendFormat": "{{ method }} {{ status }}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "p99 Latency",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{job=\"headscale\"}[5m]))",
          "legendFormat": "p99"
        },
        {
          "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{job=\"headscale\"}[5m]))",
          "legendFormat": "p50"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Node Count Over Time",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "targets": [
        {
          "expr": "headscale_nodes_total",
          "legendFormat": "nodes"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "DERP Map Updates",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "targets": [
        {
          "expr": "rate(headscale_derp_map_updates_total[5m])",
          "legendFormat": "derp map updates/s"
        }
      ]
    }
  ]
}
